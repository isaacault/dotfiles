{{- /* Machine identity: prompted once at `chezmoi init`, stored in the local
       (untracked) ~/.config/chezmoi/chezmoi.toml. Re-init never re-prompts.
       Prompt strings are deliberately the bare flag names so scripted init
       works: chezmoi init --promptBool work=true,gui=false,provision=false \
                           --promptString email=me@work.example,overlay=git@host:me/overlay.git
       work      — work machine: prompts for work git email + an optional
                   overlay repo URL. Work values are per-machine DATA, never
                   committed: they live only in this machine's untracked config.
       gui       — GUI desktop: sway/waybar/... (linux), aerospace (mac)
       provision — install packages on first apply (needs sudo or brew) */ -}}
{{- $work := promptBoolOnce . "work" "work" false -}}
{{- $gui := promptBoolOnce . "gui" "gui" false -}}
{{- $provision := promptBoolOnce . "provision" "provision" false -}}
{{- $email := "isaac.ault@gmail.com" -}}
{{- $overlay := "" -}}
{{- if $work -}}
{{-   $email = promptStringOnce . "email" "email" -}}
{{-   $overlay = promptStringOnce . "overlay" "overlay" -}}
{{- end -}}

[data]
    work = {{ $work }}
    gui = {{ $gui }}
    provision = {{ $provision }}
    email = {{ $email | quote }}
    overlay = {{ $overlay | quote }}
