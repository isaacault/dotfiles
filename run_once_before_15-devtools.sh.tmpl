{{ if .devtools -}}
#!/bin/bash
# SPDX-License-Identifier: MIT
# Enhanced CLI dev tools (eza, bat, zoxide, uv, glab, node).
# Runs once per machine (chezmoi run_once_before_), only when devtools=true.
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
brew install {{ .devtools.brew | join " " }}

{{ else -}}
SUDO=""
[ "$(id -u)" -ne 0 ] && SUDO="sudo"

if command -v apt-get >/dev/null 2>&1; then
  $SUDO apt-get update -qq
  $SUDO apt-get install -y -qq {{ .devtools.apt | join " " }}
elif command -v dnf >/dev/null 2>&1; then
  $SUDO dnf install -y -q {{ .devtools.dnf | join " " }}
fi

# zoxide: not in standard apt/dnf repos
if ! command -v zoxide >/dev/null 2>&1; then
  curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# uv: not in standard apt/dnf repos
if ! command -v uv >/dev/null 2>&1; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# glab: not in standard apt/dnf repos
if ! command -v glab >/dev/null 2>&1; then
  GLAB_VERSION=$(curl -fsSL https://gitlab.com/api/v4/projects/34675721/releases | grep -oP '"tag_name":"\Kv[^"]+' | head -1)
  GLAB_URL="https://gitlab.com/gitlab-org/cli/-/releases/${GLAB_VERSION}/downloads/glab_${GLAB_VERSION#v}_linux_amd64.tar.gz"
  curl -fsSL "$GLAB_URL" | tar xz -C "$HOME/.local/bin" --strip-components=2 bin/glab
fi
{{ end -}}
{{ end -}}
